# =============================================================
# Configuration de l'agente virtuelle RH
# =============================================================
# Copie ce fichier en .env et complète les valeurs.

# --- OBLIGATOIRE : clé API Anthropic ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- LANGUE de l'agente (FR ou DE) ---
# FR = français (cantons romands : VD, GE, NE, JU, FR, VS)
# DE = allemand (cantons alémaniques : ZH, BE, BS, ZG, etc.)
LANGUE=FR


# --- OPTIONNEL : connexion Gmail (lecture + envoi) ---
# 1. Active la 2FA sur ton compte Google
# 2. Crée un "mot de passe d'application" : https://myaccount.google.com/apppasswords
# 3. Colle l'adresse Gmail et le mot de passe d'application (16 caractères, sans espaces)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=


# --- OPTIONNEL : connexion Outlook / Microsoft 365 (lecture + envoi) ---
# 1. Active la 2FA sur ton compte Microsoft
# 2. Crée un mot de passe d'application : https://account.live.com/proofs/AppPassword
#    (pour M365 entreprise, demande à ton admin Azure d'autoriser SMTP/IMAP basic auth
#     ou utilise plutôt une intégration OAuth)
# 3. Renseigne ton adresse et ton mot de passe d'application
OUTLOOK_ADDRESS=
OUTLOOK_APP_PASSWORD=
